{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { chatWithAI } from '@/api/ai';\nexport default {\n  name: 'AIChat',\n  data() {\n    return {\n      showChat: false,\n      messages: [{\n        id: Date.now() + Math.random().toString(36).slice(2, 8),\n        role: 'assistant',\n        content: '您好！我是自习室智能助手，有什么可以帮您的？😊'\n      }],\n      inputMessage: '',\n      loading: false,\n      quickQuestions: ['如何预约自习室？', '推荐安静的座位', '今天有空位吗？', '取消预约怎么操作？']\n    };\n  },\n  methods: {\n    // 移到methods中，解决Vue 2不支持顶层函数的问题\n    generateUniqueId() {\n      return Date.now() + Math.random().toString(36).slice(2, 8);\n    },\n    toggleChat() {\n      this.showChat = !this.showChat;\n      if (this.showChat) {\n        this.$nextTick(() => {\n          this.scrollToBottom();\n        });\n      }\n    },\n    async sendMessage() {\n      if (!this.inputMessage.trim() || this.loading) return;\n      const userMessage = this.inputMessage.trim();\n      console.log('用户输入内容：', userMessage);\n\n      // 调用methods中的方法生成id\n      this.messages.push({\n        id: this.generateUniqueId(),\n        role: 'user',\n        content: userMessage\n      });\n      this.inputMessage = '';\n      this.loading = true;\n      this.scrollToBottom();\n      try {\n        const res = await chatWithAI(userMessage);\n        console.log('接口原始响应：', res);\n        let aiContent = '抱歉，暂无回答';\n        if (res.data && res.data.code === 200) {\n          aiContent = res.data.data || aiContent;\n        } else if (res.data) {\n          aiContent = typeof res.data === 'string' ? res.data : JSON.stringify(res.data);\n        } else if (res) {\n          aiContent = typeof res === 'string' ? res : '抱歉，未获取到回答';\n        }\n        this.messages.push({\n          id: this.generateUniqueId(),\n          role: 'assistant',\n          content: aiContent\n        });\n      } catch (error) {\n        console.error('请求错误详情：', {\n          url: error.config?.url,\n          requestData: error.config?.data,\n          status: error.response?.status,\n          responseData: error.response?.data,\n          message: error.message\n        });\n        this.messages.push({\n          id: this.generateUniqueId(),\n          role: 'assistant',\n          content: '网络错误，请重试'\n        });\n      } finally {\n        this.loading = false;\n        this.scrollToBottom();\n      }\n    },\n    askQuestion(question) {\n      this.inputMessage = question;\n      this.sendMessage();\n    },\n    scrollToBottom() {\n      this.$nextTick(() => {\n        const container = this.$refs.messagesContainer;\n        if (container) {\n          container.scrollTop = container.scrollHeight;\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["chatWithAI","name","data","showChat","messages","id","Date","now","Math","random","toString","slice","role","content","inputMessage","loading","quickQuestions","methods","generateUniqueId","toggleChat","$nextTick","scrollToBottom","sendMessage","trim","userMessage","console","log","push","res","aiContent","code","JSON","stringify","error","url","config","requestData","status","response","responseData","message","askQuestion","question","container","$refs","messagesContainer","scrollTop","scrollHeight"],"sources":["src/components/AIChat.vue"],"sourcesContent":["<!-- src/components/AIChat.vue -->\r\n<template>\r\n  <div class=\"ai-chat-container\">\r\n    <!-- 触发按钮 -->\r\n    <div class=\"ai-chat-trigger\" @click=\"toggleChat\">\r\n      <svg class=\"icon-robot\" viewBox=\"0 0 1024 1024\" width=\"24\" height=\"24\">\r\n        <path d=\"M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372z\" fill=\"#ffffff\"/>\r\n        <path d=\"M464 336a48 48 0 1 0 96 0 48 48 0 1 0-96 0z m-48 236h192v48H416v-48z\" fill=\"#ffffff\"/>\r\n      </svg>\r\n      <span>AI助手</span>\r\n    </div>\r\n    \r\n    <!-- 聊天窗口 -->\r\n    <transition name=\"slide-up\">\r\n      <div class=\"chat-window\" v-show=\"showChat\">\r\n        <div class=\"chat-header\">\r\n          <h3>🤖 AI智能助手</h3>\r\n          <button class=\"close-btn\" @click=\"showChat = false\">×</button>\r\n        </div>\r\n        \r\n        <div class=\"chat-messages\" ref=\"messagesContainer\">\r\n          <!-- 恢复index，避免Vue 2解析歧义 -->\r\n          <div \r\n            v-for=\"(msg, index) in messages\" \r\n            :key=\"msg.id\" \r\n            :class=\"['message', msg.role]\"\r\n          >\r\n            <div class=\"avatar\">\r\n              <span v-if=\"msg.role === 'user'\">👤</span>\r\n              <span v-else>🤖</span>\r\n            </div>\r\n            <div class=\"message-content\">\r\n              {{ msg.content }}\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 加载动画 -->\r\n          <div v-if=\"loading\" class=\"message assistant\">\r\n            <div class=\"avatar\">🤖</div>\r\n            <div class=\"message-content typing\">\r\n              <span></span><span></span><span></span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 快捷问题 -->\r\n        <div class=\"quick-questions\" v-if=\"messages.length <= 1\">\r\n          <button \r\n            v-for=\"(q, index) in quickQuestions\" \r\n            :key=\"index\" \r\n            @click=\"askQuestion(q)\"\r\n            class=\"quick-btn\"\r\n          >\r\n            {{ q }}\r\n          </button>\r\n        </div>\r\n        \r\n        <!-- 输入框 -->\r\n        <div class=\"chat-input\">\r\n          <input \r\n            v-model=\"inputMessage\"\r\n            @keyup.enter=\"sendMessage\"\r\n            placeholder=\"有什么可以帮您的？\"\r\n            :disabled=\"loading\"\r\n          />\r\n          <button @click=\"sendMessage\" :disabled=\"loading || !inputMessage.trim()\">\r\n            <svg viewBox=\"0 0 24 24\" width=\"20\" height=\"20\">\r\n              <path d=\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\" fill=\"currentColor\"/>\r\n            </svg>\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { chatWithAI } from '@/api/ai'\r\n\r\nexport default {\r\n  name: 'AIChat',\r\n  data() {\r\n    return {\r\n      showChat: false,\r\n      messages: [\r\n        { \r\n          id: Date.now() + Math.random().toString(36).slice(2, 8),\r\n          role: 'assistant', \r\n          content: '您好！我是自习室智能助手，有什么可以帮您的？😊' \r\n        }\r\n      ],\r\n      inputMessage: '',\r\n      loading: false,\r\n      quickQuestions: [\r\n        '如何预约自习室？',\r\n        '推荐安静的座位',\r\n        '今天有空位吗？',\r\n        '取消预约怎么操作？'\r\n      ]\r\n    }\r\n  },\r\n  methods: {\r\n    // 移到methods中，解决Vue 2不支持顶层函数的问题\r\n    generateUniqueId() {\r\n      return Date.now() + Math.random().toString(36).slice(2, 8)\r\n    },\r\n    toggleChat() {\r\n      this.showChat = !this.showChat\r\n      if (this.showChat) {\r\n        this.$nextTick(() => {\r\n          this.scrollToBottom()\r\n        })\r\n      }\r\n    },\r\n    async sendMessage() {\r\n      if (!this.inputMessage.trim() || this.loading) return\r\n\r\n      const userMessage = this.inputMessage.trim()\r\n      console.log('用户输入内容：', userMessage)\r\n      \r\n      // 调用methods中的方法生成id\r\n      this.messages.push({ \r\n        id: this.generateUniqueId(),\r\n        role: 'user', \r\n        content: userMessage \r\n      })\r\n      this.inputMessage = ''\r\n      this.loading = true\r\n\r\n      this.scrollToBottom()\r\n\r\n      try {\r\n        const res = await chatWithAI(userMessage)\r\n        console.log('接口原始响应：', res)\r\n\r\n        let aiContent = '抱歉，暂无回答'\r\n        if (res.data && res.data.code === 200) {\r\n          aiContent = res.data.data || aiContent\r\n        } else if (res.data) {\r\n          aiContent = typeof res.data === 'string' ? res.data : JSON.stringify(res.data)\r\n        } else if (res) {\r\n          aiContent = typeof res === 'string' ? res : '抱歉，未获取到回答'\r\n        }\r\n\r\n        this.messages.push({\r\n          id: this.generateUniqueId(),\r\n          role: 'assistant',\r\n          content: aiContent\r\n        })\r\n      } catch (error) {\r\n        console.error('请求错误详情：', {\r\n          url: error.config?.url,\r\n          requestData: error.config?.data,\r\n          status: error.response?.status,\r\n          responseData: error.response?.data,\r\n          message: error.message\r\n        })\r\n        this.messages.push({\r\n          id: this.generateUniqueId(),\r\n          role: 'assistant',\r\n          content: '网络错误，请重试'\r\n        })\r\n      } finally {\r\n        this.loading = false\r\n        this.scrollToBottom()\r\n      }\r\n    },\r\n    askQuestion(question) {\r\n      this.inputMessage = question\r\n      this.sendMessage()\r\n    },\r\n    scrollToBottom() {\r\n      this.$nextTick(() => {\r\n        const container = this.$refs.messagesContainer\r\n        if (container) {\r\n          container.scrollTop = container.scrollHeight\r\n        }\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.ai-chat-container {\r\n  position: fixed;\r\n  bottom: 30px;\r\n  right: 30px;\r\n  z-index: 9999;\r\n}\r\n\r\n.ai-chat-trigger {\r\n  width: 60px;\r\n  height: 60px;\r\n  border-radius: 50%;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  border: none;\r\n  cursor: pointer;\r\n  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 11px;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.ai-chat-trigger:hover {\r\n  transform: scale(1.1);\r\n  box-shadow: 0 6px 25px rgba(102, 126, 234, 0.6);\r\n}\r\n\r\n.icon-robot {\r\n  margin-bottom: 2px;\r\n}\r\n\r\n.chat-window {\r\n  position: absolute;\r\n  bottom: 80px;\r\n  right: 0;\r\n  width: 380px;\r\n  height: 600px;\r\n  background: white;\r\n  border-radius: 16px;\r\n  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n}\r\n\r\n.slide-up-enter-active, .slide-up-leave-active {\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.slide-up-enter-from {\r\n  transform: translateY(20px);\r\n  opacity: 0;\r\n}\r\n\r\n.slide-up-leave-to {\r\n  transform: translateY(20px);\r\n  opacity: 0;\r\n}\r\n\r\n.chat-header {\r\n  padding: 18px 20px;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.chat-header h3 {\r\n  margin: 0;\r\n  font-size: 16px;\r\n  font-weight: 600;\r\n}\r\n\r\n.close-btn {\r\n  background: none;\r\n  border: none;\r\n  color: white;\r\n  font-size: 28px;\r\n  cursor: pointer;\r\n  width: 30px;\r\n  height: 30px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  border-radius: 50%;\r\n  transition: background 0.3s;\r\n}\r\n\r\n.close-btn:hover {\r\n  background: rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.chat-messages {\r\n  flex: 1;\r\n  padding: 20px;\r\n  overflow-y: auto;\r\n  background: #f8f9fa;\r\n}\r\n\r\n.chat-messages::-webkit-scrollbar {\r\n  width: 6px;\r\n}\r\n\r\n.chat-messages::-webkit-scrollbar-thumb {\r\n  background: #cbd5e0;\r\n  border-radius: 3px;\r\n}\r\n\r\n.message {\r\n  margin-bottom: 16px;\r\n  display: flex;\r\n  gap: 10px;\r\n  animation: fadeIn 0.3s ease;\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(10px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0);\r\n  }\r\n}\r\n\r\n.message.user {\r\n  flex-direction: row-reverse;\r\n}\r\n\r\n.avatar {\r\n  width: 32px;\r\n  height: 32px;\r\n  border-radius: 50%;\r\n  background: white;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 18px;\r\n  flex-shrink: 0;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.message-content {\r\n  max-width: 70%;\r\n  padding: 12px 16px;\r\n  border-radius: 12px;\r\n  word-wrap: break-word;\r\n  line-height: 1.5;\r\n  font-size: 14px;\r\n}\r\n\r\n.message.user .message-content {\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  border-bottom-right-radius: 4px;\r\n}\r\n\r\n.message.assistant .message-content {\r\n  background: white;\r\n  color: #2d3748;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\r\n  border-bottom-left-radius: 4px;\r\n}\r\n\r\n.typing {\r\n  display: flex;\r\n  gap: 4px;\r\n  padding: 16px;\r\n}\r\n\r\n.typing span {\r\n  width: 8px;\r\n  height: 8px;\r\n  border-radius: 50%;\r\n  background: #999;\r\n  animation: typing 1.4s infinite;\r\n}\r\n\r\n.typing span:nth-child(2) { animation-delay: 0.2s; }\r\n.typing span:nth-child(3) { animation-delay: 0.4s; }\r\n\r\n@keyframes typing {\r\n  0%, 60%, 100% { transform: translateY(0); }\r\n  30% { transform: translateY(-10px); }\r\n}\r\n\r\n.quick-questions {\r\n  padding: 12px 16px;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  background: white;\r\n  border-top: 1px solid #e2e8f0;\r\n}\r\n\r\n.quick-btn {\r\n  padding: 8px 14px;\r\n  background: #f7fafc;\r\n  border: 1px solid #e2e8f0;\r\n  border-radius: 20px;\r\n  cursor: pointer;\r\n  font-size: 13px;\r\n  color: #4a5568;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.quick-btn:hover {\r\n  background: #edf2f7;\r\n  border-color: #667eea;\r\n  color: #667eea;\r\n}\r\n\r\n.chat-input {\r\n  display: flex;\r\n  padding: 16px;\r\n  background: white;\r\n  border-top: 1px solid #e2e8f0;\r\n  gap: 10px;\r\n}\r\n\r\n.chat-input input {\r\n  flex: 1;\r\n  padding: 12px 16px;\r\n  border: 1px solid #e2e8f0;\r\n  border-radius: 24px;\r\n  outline: none;\r\n  font-size: 14px;\r\n  transition: border-color 0.3s;\r\n}\r\n\r\n.chat-input input:focus {\r\n  border-color: #667eea;\r\n}\r\n\r\n.chat-input input:disabled {\r\n  background: #f7fafc;\r\n  cursor: not-allowed;\r\n}\r\n\r\n.chat-input button {\r\n  width: 44px;\r\n  height: 44px;\r\n  padding: 0;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  border: none;\r\n  border-radius: 50%;\r\n  cursor: pointer;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.chat-input button:hover:not(:disabled) {\r\n  transform: scale(1.05);\r\n  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);\r\n}\r\n\r\n.chat-input button:disabled {\r\n  opacity: 0.5;\r\n  cursor: not-allowed;\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .chat-window {\r\n    width: calc(100vw - 40px);\r\n    height: calc(100vh - 120px);\r\n    right: 20px;\r\n  }\r\n  \r\n  .ai-chat-trigger {\r\n    right: 20px;\r\n    bottom: 20px;\r\n  }\r\n}\r\n</style>"],"mappings":";AA6EA,SAAAA,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,QAAA,GACA;QACAC,EAAA,EAAAC,IAAA,CAAAC,GAAA,KAAAC,IAAA,CAAAC,MAAA,GAAAC,QAAA,KAAAC,KAAA;QACAC,IAAA;QACAC,OAAA;MACA,EACA;MACAC,YAAA;MACAC,OAAA;MACAC,cAAA,GACA,YACA,WACA,WACA;IAEA;EACA;EACAC,OAAA;IACA;IACAC,iBAAA;MACA,OAAAZ,IAAA,CAAAC,GAAA,KAAAC,IAAA,CAAAC,MAAA,GAAAC,QAAA,KAAAC,KAAA;IACA;IACAQ,WAAA;MACA,KAAAhB,QAAA,SAAAA,QAAA;MACA,SAAAA,QAAA;QACA,KAAAiB,SAAA;UACA,KAAAC,cAAA;QACA;MACA;IACA;IACA,MAAAC,YAAA;MACA,UAAAR,YAAA,CAAAS,IAAA,WAAAR,OAAA;MAEA,MAAAS,WAAA,QAAAV,YAAA,CAAAS,IAAA;MACAE,OAAA,CAAAC,GAAA,YAAAF,WAAA;;MAEA;MACA,KAAApB,QAAA,CAAAuB,IAAA;QACAtB,EAAA,OAAAa,gBAAA;QACAN,IAAA;QACAC,OAAA,EAAAW;MACA;MACA,KAAAV,YAAA;MACA,KAAAC,OAAA;MAEA,KAAAM,cAAA;MAEA;QACA,MAAAO,GAAA,SAAA5B,UAAA,CAAAwB,WAAA;QACAC,OAAA,CAAAC,GAAA,YAAAE,GAAA;QAEA,IAAAC,SAAA;QACA,IAAAD,GAAA,CAAA1B,IAAA,IAAA0B,GAAA,CAAA1B,IAAA,CAAA4B,IAAA;UACAD,SAAA,GAAAD,GAAA,CAAA1B,IAAA,CAAAA,IAAA,IAAA2B,SAAA;QACA,WAAAD,GAAA,CAAA1B,IAAA;UACA2B,SAAA,UAAAD,GAAA,CAAA1B,IAAA,gBAAA0B,GAAA,CAAA1B,IAAA,GAAA6B,IAAA,CAAAC,SAAA,CAAAJ,GAAA,CAAA1B,IAAA;QACA,WAAA0B,GAAA;UACAC,SAAA,UAAAD,GAAA,gBAAAA,GAAA;QACA;QAEA,KAAAxB,QAAA,CAAAuB,IAAA;UACAtB,EAAA,OAAAa,gBAAA;UACAN,IAAA;UACAC,OAAA,EAAAgB;QACA;MACA,SAAAI,KAAA;QACAR,OAAA,CAAAQ,KAAA;UACAC,GAAA,EAAAD,KAAA,CAAAE,MAAA,EAAAD,GAAA;UACAE,WAAA,EAAAH,KAAA,CAAAE,MAAA,EAAAjC,IAAA;UACAmC,MAAA,EAAAJ,KAAA,CAAAK,QAAA,EAAAD,MAAA;UACAE,YAAA,EAAAN,KAAA,CAAAK,QAAA,EAAApC,IAAA;UACAsC,OAAA,EAAAP,KAAA,CAAAO;QACA;QACA,KAAApC,QAAA,CAAAuB,IAAA;UACAtB,EAAA,OAAAa,gBAAA;UACAN,IAAA;UACAC,OAAA;QACA;MACA;QACA,KAAAE,OAAA;QACA,KAAAM,cAAA;MACA;IACA;IACAoB,YAAAC,QAAA;MACA,KAAA5B,YAAA,GAAA4B,QAAA;MACA,KAAApB,WAAA;IACA;IACAD,eAAA;MACA,KAAAD,SAAA;QACA,MAAAuB,SAAA,QAAAC,KAAA,CAAAC,iBAAA;QACA,IAAAF,SAAA;UACAA,SAAA,CAAAG,SAAA,GAAAH,SAAA,CAAAI,YAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}